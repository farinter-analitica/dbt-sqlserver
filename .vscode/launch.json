{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Current File (Debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "pythonArgs": ["-Xfrozen_modules=off"],
            "justMyCode": true,
            "console": "integratedTerminal",
            "purpose": ["debug-in-terminal"],
        }
    ]
}