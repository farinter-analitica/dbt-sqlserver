{
    "dbt.enableNewLineagePanel": true,
    "python.analysis.autoImportCompletions": true,
    "python.analysis.diagnosticMode": "workspace",
    // Usar wrapper para discovery/run que despacha a cada .venv pytest
    "python.testing.unittestEnabled": false,
    "python.testing.pytestEnabled": false,
    //"python.testing.autoTestDiscoverOnSaveEnabled": true,
    //"python.testing.autoTestDiscoverOnSavePattern": "**/test*.py",
    "dbt.perspectiveTheme": "Vintage",
    //"python.envFile": "${workspaceFolder}/.env",
    "[sql]": {
        "editor.defaultFormatter": "dorzey.vscode-sqlfluff"
    },
    "[jinja-sql]": {
        "editor.defaultFormatter": "dorzey.vscode-sqlfluff"
    },
    "github.copilot.chat.commitMessageGeneration.instructions": [
        {
            "file": "templates/commit-template.git.txt",
        }
    ],
    "sqlfluff.linter.run": "onSave",
    "sqlfluff.experimental.format.executeInTerminal": true,
    "sqlfluff.executablePath": "${env:DAGSTER_HOME}/scripts/sqlfluff.sh",
    "editor.formatOnSave": false,
    "dbt.queryLimit": 1000
}