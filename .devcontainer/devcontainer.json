{
	"name": "main-dagster",
	"dockerComposeFile": [
		"docker-compose.dev.yaml"
	],
	"service": "dev",
	"forwardPorts": [
		3000
	],
	"shutdownAction": "stopCompose",
	"customizations": {
		"vscode": {
			"extensions": [
				"charliermarsh.ruff",
				"ms-python.python",
				"ms-python.vscode-pylance",
				"sourcegraph.cody-ai",
				"redhat.vscode-yaml",
				"tamasfe.even-better-toml",
				"samuelcolvin.jinjahtml",
				"innoverio.vscode-dbt-power-user"
			],
			"settings": {
				"python.defaultInterpreterPath": "./.venv/bin/python",
				"terminal.integrated.defaultProfile.linux": "zsh",
				"terminal.integrated.profiles.linux": {
					"zsh": {
						"path": "/usr/bin/zsh"
					}
				}
			}
		}
	},
	"features": {
		"ghcr.io/devcontainers/features/common-utils": {
			"installZsh": true,
			"installOhMyZsh": true,
			"installOhMyZshConfig": true,
			"configureZshAsDefaultShell": true
		},
		"ghcr.io/devcontainers-extra/features/zsh-plugins:0": {
			"plugins": "zsh-autosuggestions zsh-syntax-highlighting",
			"omzPlugins": "https://github.com/zsh-users/zsh-autosuggestions.git https://github.com/zsh-users/zsh-syntax-highlighting.git"
		}
	},
	"workspaceFolder": "/workspaces/main-dagster",
	"postCreateCommand": "/bin/bash .devcontainer/post_create.sh && /bin/bash .devcontainer/setup_odbc.sh",
	"containerEnv": {
		//Disponibles en todo el contenedor
		"DISPLAY": "dummy",
		"PYTHONUNBUFFERED": "True",
		"UV_LINK_MODE": "copy",
		"UV_PROJECT_ENVIRONMENT": "${containerWorkspaceFolder}/.venv"
	},
	"remoteEnv": {
		// Esto nos ayuda con las herramientas de vscode en general
		"PATH": "${containerEnv:VIRTUAL_ENV}/bin:${containerEnv:PATH}",
		"PYTHONPATH": "${containerWorkspaceFolder}"
	},
	//para usar el mismo .env en repo nuevo
	"initializeCommand": "sh .devcontainer/setup_env.sh"
}